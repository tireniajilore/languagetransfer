          "hash": "4997811db289ea317c2514c67eb790e3b43a09435765447884340a324b98cbf4"
        },
        {
          "text": "diente,",
          "lang": "es",
          "file": "turn-53-full-5.mp3",
          "hash": "1b3c1c0a074a57b1deb4d684959d3159579ecd9353ba91cbcb9405b24af400ff"
        },
        {
          "text": "rather than treating it as random vocabulary to memorize, you can relate it back to dental.",
          "lang": "en",
          "file": "turn-53-full-6.mp3",
          "hash": "b0747d8eae5c3e13ab5fb9a81149ac7eecdddf9da3d92f0b50c47b4a568e35e8"
        }
      ]
    },
    "turn-54-full": {
      "segments": [
        {
          "text": "How would you say verbal?",
          "lang": "en",
          "file": "turn-54-full-1.mp3",
          "hash": "151700aab561557c643a9373d4715d820c26c5a039bf353325f66e1ac35ca957"
        }
      ]
    },
    "turn-56-full": {
      "segments": [
        {
          "text": "Verbal.",
          "lang": "es",
          "file": "turn-56-full-1.mp3",
          "hash": "186bd1a12b377afad4015564b3a9cf482f798b5a927e213e2a1f3a63498f6965"
        },
        {
          "text": "Good. So knowing 'verbal', you can probably guess the word for 'verb' in Spanish.",
          "lang": "en",
          "file": "turn-56-full-2.mp3",
          "hash": "7c28cc9ccc5b8263f4a86c6e3c06bc9e3532ccf5a0dbff87c7c0f6544643e431"
        }
      ]
    },
    "turn-57-full": {
      "segments": [
        {
          "text": "How do you think you say verb in Spanish?",
          "lang": "en",
          "file": "turn-57-full-1.mp3",
          "hash": "6f8dfacb9bcb7f94c2e37bbe5304ea6980a8f88c94b6948135930a47748d2140"
        }
      ]
    },
    "turn-59-full": {
      "segments": [
        {
          "text": "Verbo.",
          "lang": "es",
          "file": "turn-59-full-1.mp3",
          "hash": "ed55d39b80f445f83d1cd4c2cc6da85523284eecbc28c75942255f1293196f47"
        },
        {
          "text": "Good. With vocabulary, it's okay to guess based on patterns. If you're a little off, a native speaker will usually still understand you, and then you can adjust. That's one of the fastest ways to build vocabulary.",
          "lang": "en",
          "file": "turn-59-full-2.mp3",
          "hash": "288c410f16c2a391f792c436b339d598e2a4e3df8ccb7e220bad71cef9ce0502"
        }
      ]
    },
    "outro-1-full": {
      "segments": [
        {
          "text": "You've now got a pattern that works for hundreds of English words. Any word ending in A-L - you already know how to say it in Spanish.",
          "lang": "en",
          "file": "outro-1-full-1.mp3",
          "hash": "20bfc317296fd90277b99a046f3b223d8769d4305ed0d8c8cb3d4d33fa102708"
        }
      ]
    },
    "outro-2-full": {
      "segments": [
        {
          "text": "Try one that we haven't covered. Think of any English word ending in A-L - maybe 'emotional', or 'professional', or 'digital' - and say it in Spanish with the stress on the end.",
          "lang": "en",
          "file": "outro-2-full-1.mp3",
          "hash": "9849e969ca1326c34e8f2c1cbad25ff4164bd8bbe7c023dbe141fd9f1d9bfbbb"
        }
      ]
    },
    "outro-3-full": {
      "segments": [
        {
          "text": "You can now describe things in a conversation. Something is normal, something is ideal, something is not legal. That's real language you can use today.",
          "lang": "en",
          "file": "outro-3-full-1.mp3",
          "hash": "eed699227168b30c056348608220afea0d6a91e20e38809615c1edad727775f2"
        }
      ]
    },
    "outro-4-full": {
      "segments": [
        {
          "text": "Next time, we'll take this same idea and look at words with different endings. You'll see how quickly your vocabulary grows once you know what to look for.",
          "lang": "en",
          "file": "outro-4-full-1.mp3",
          "hash": "fb6f0bd0f82198007dac65b0adc0e3ea922bacc9f812d2f5d3b75b668d641991"
        }
      ]
    }
  }
}
