          "file": "outro-1-full-1.mp3",
          "hash": "4b1dcb6d6e7a8f22dd7fcda5faf6c57bed3bc3332469fed1d0501399d84ce75e"
        }
      ]
    },
    "outro-2-full": {
      "segments": [
        {
          "text": "Try forming 'I' forms from other verbs you know, like 'to study' or 'to write'.",
