          "hash": "09c4eb6d87a50eab628c597b58d127e9c388f548e8085a38aa4d70722e50f336"
        }
      ]
    },
    "outro-3-full": {
      "segments": [
        {
          "text": "Remember, regular verbs change from -ar, -er, or -ir to -o in the 'I' form, and some irregular verbs have unique forms.",
          "lang": "en",
