          "file": "turn-1-full-1.mp3",
          "hash": "d91381200ee3c603005ff633b7218049c8fc0414186624a36c5367886d9ec016"
        }
      ]
    },
    "turn-2-full": {
      "segments": [
        {
          "text": "How do you say 'I start' using empezar?",
          "lang": "en",
          "file": "turn-2-full-1.mp3",
          "hash": "63075d38c87f7b4cc2f2f7817627ec55d1ce429dd151b40344c65d9f8d5dd6e2"
        }
      ]
    },
    "turn-4-reveal": {
