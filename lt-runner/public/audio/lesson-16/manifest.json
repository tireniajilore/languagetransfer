    "outro-1-full": {
      "segments": [
        {
          "text": "You've learned about stem-changing verbs in Spanish, like empezar and dormir. These changes occur in the present tense.",
          "lang": "en",
          "file": "outro-1-full-1.mp3",
          "hash": "7c9c5465635caeefb5d7659f0eaaa6de21f4f51c8ad1d3f6b7ff67e3fe18e1ed"
        }
      ]
    },
    "outro-2-full": {
      "segments": [
        {
          "text": "Try conjugating other stem-changing verbs like poder or volver. Remember the vowel changes in the stem.",
