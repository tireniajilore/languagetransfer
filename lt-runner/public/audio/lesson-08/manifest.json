    "turn-1-full": {
      "segments": [
        {
          "text": "What was the word for 'it', 'him', or 'you' (formal)?",
          "lang": "en",
          "file": "turn-1-full-1.mp3",
          "hash": "d6e1e6398130c40220b760ab5749eb2b174482a08085318f5f4679bfadf5f9a8"
        }
      ]
    },
    "turn-3-reveal": {
      "segments": [
        {
          "text": "Lo. To make it feminine, change the 'o' to 'a', giving us la. This means 'her', 'it' (for feminine nouns), or 'you' (formal, feminine). For example, 'casa' (house) is feminine.",
          "lang": "en",
          "file": "turn-3-reveal-1.mp3",
          "hash": "edc6824b3527e54969c10da2189992ceb5af0eceb35f6f07b7caf0737a36089a"
        }
      ]
    },
    "turn-3-prompt": {
      "segments": [
        {
          "text": "How would you say 'I want to see it', referring to the house?",
          "lang": "en",
          "file": "turn-3-prompt-1.mp3",
          "hash": "3cef25189acd4a71f201cbb867da3e319626f82972cfa425708375aa2607af8c"
        }
      ]
    },
    "turn-5-reveal": {
      "segments": [
        {
          "text": "Quiero verla.",
          "lang": "es",
          "file": "turn-5-reveal-1.mp3",
          "hash": "16f79366009e2c3b6a86d1faded1c8ec33c1eb2faecaff8f3d582550857fd3c5"
        },
        {
          "text": "This could also mean 'I want to see her'. 'La' could mean 'her', 'it', or 'you' (formal, feminine). The use of formal language varies by region, so it's safe to start formally with 'lo' or 'la'. 'Quiere' means 'he wants', 'she wants', 'it wants', or 'you (formal) want'.",
          "lang": "en",
          "file": "turn-5-reveal-2.mp3",
          "hash": "b5349e20c25b5448ff148b6f0ddd13073121cd9ee2f687fdf2afb718c1f87776"
        }
      ]
    },
