          "hash": "69b4cb7ec400c3cce7b9f1130780bd0e6d55ba3ff60b75455ccc93c20cf75eb6"
        }
      ]
    },
    "turn-51-prompt": {
      "segments": [
        {
          "text": "How would you say 'I want to explore'?",
          "lang": "en",
          "file": "turn-51-prompt-1.mp3",
          "hash": "36604309d141ac3ba95105271e0ec0da2b50717146ff25c823851444480a95d0"
        }
      ]
    },
    "turn-53-reveal": {
      "segments": [
        {
          "text": "Quiero explorar.",
          "lang": "es",
          "file": "turn-53-reveal-1.mp3",
          "hash": "efa05c9fc4ecedd8be4929af617c07f6ce19fce25a46efd11eb37b1bca917ac7"
        },
        {
          "text": "Perfect. The word for 'me' in Spanish is 'me'.",
          "lang": "en",
          "file": "turn-53-reveal-2.mp3",
          "hash": "ab4f8aca3cd5227d4963effad6f5d4192d010572160ec6babe551a380e44ea86"
        }
      ]
    },
    "turn-53-prompt": {
      "segments": [
        {
          "text": "How would you say 'I want to prepare myself'?",
          "lang": "en",
          "file": "turn-53-prompt-1.mp3",
          "hash": "9fb5d7fac91b3e893d5a1a1860ed70bd82cc2482b8c9b9a2f522dcd2f0dd47c6"
        }
      ]
    },
    "turn-55-full": {
      "segments": [
        {
          "text": "Quiero prepararme.",
          "lang": "es",
          "file": "turn-55-full-1.mp3",
          "hash": "68c4b0134de033bc5fe528dbd63abefcc0d19ddc0e21447ada1129dfa9a933f5"
        },
        {
          "text": "Good. In English, Latin words can sound formal, but in Spanish, they sound normal.",
          "lang": "en",
          "file": "turn-55-full-2.mp3",
          "hash": "a7c9e7c391f69ac35dda64c6def0744ff99d6bb268d77b88f4fe722586fa129a"
        }
      ]
    },
    "outro-1-full": {
      "segments": [
        {
          "text": "You've learned how to convert English words ending in -ion to Spanish by stressing the last syllable.",
          "lang": "en",
          "file": "outro-1-full-1.mp3",
          "hash": "6bea5c64b38be68910f10063d6eafa3bf829c1c5f90bc4682f6481c669197ee5"
        }
      ]
    },
    "outro-2-full": {
      "segments": [
        {
          "text": "Try converting some other -ion words like 'celebration' or 'imagination' to Spanish.",
          "lang": "en",
          "file": "outro-2-full-1.mp3",
          "hash": "6ef87b161249caafad67d10e91a6e764d12757547bc7464735488d720b0b957b"
        }
      ]
    },
    "outro-3-full": {
      "segments": [
        {
          "text": "You can now form basic sentences using these words and verbs. Practice saying what you want to do or don't want to do.",
          "lang": "en",
