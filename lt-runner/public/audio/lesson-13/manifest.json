    "turn-13-full": {
      "segments": [
        {
          "text": "¿Qué haces? This can also mean 'how are you' or 'what are you up to'. For -ar verbs, we add 'n' for 'they' or 'you (plural)', and 's' for informal 'you'. For -er/-ir verbs, we add 's' for informal 'you', 'n' for 'they', 'you (plural)'.",
          "lang": "en",
          "file": "turn-13-full-1.mp3",
          "hash": "2bfd92450d1ed6b982be693252dcbc691b6100c457c694b2d4b19c99f77e57f7"
        }
      ]
    },
    "turn-14-full": {
      "segments": [
        {
          "text": "Puedo in Spanish means 'I can' or 'I am able'. How would you say 'he can' or 'she can'?",
